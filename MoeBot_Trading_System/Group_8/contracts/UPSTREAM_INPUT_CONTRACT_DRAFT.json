{
  "contract_version": "0.1.0-draft",
  "status": "DRAFT_NOT_FROZEN",
  "lineage": "dukascopy_rebuild_v1",
  "read_only": true,
  "general_rules": [
    "Every opened SQLite dependency must use read-only mode.",
    "Verify exact filename, byte size and SHA-256 before schema inspection or row access.",
    "Reject a dependency whose config, schema, engine, source fingerprint or lineage differs from the accepted registry.",
    "Do not infer an upstream table name or field name when exact schema introspection has not completed.",
    "Preserve upstream deterministic IDs unchanged; Group 8 creates only relationship and interpretation IDs.",
    "No Group 8 record may be available before every mandatory upstream record and source bar is available."
  ],
  "inputs": {
    "group1_canonical_bars": {
      "role": "mandatory direct price and time source",
      "minimum_table": "bars",
      "required_fields": [
        "id",
        "symbol",
        "timeframe",
        "open_time",
        "close_time",
        "available_at",
        "open",
        "high",
        "low",
        "close",
        "content_hash"
      ],
      "optional_verified_fields": [
        "tick_volume",
        "real_volume",
        "spread_points"
      ],
      "rules": [
        "Use closed bars only.",
        "Optional volume or spread fields may be used only after exact schema and provenance verification.",
        "Never manufacture missing bars or interpolate OHLC."
      ]
    },
    "group2_regime": {
      "role": "market-regime and higher-context interpretation",
      "runtime_identity": "0.2.1/schema 2.1.0",
      "required_semantic_fields": [
        "deterministic regime or state ID",
        "symbol",
        "timeframe",
        "regime classification",
        "event_time",
        "confirmation_time",
        "availability_time",
        "strength or confidence fields when present",
        "ambiguity or uncertainty fields when present",
        "config ID",
        "feature hash",
        "record hash"
      ],
      "exact_table_adapter": "PENDING_LOCAL_SCHEMA_INTROSPECTION",
      "prohibition": "Group 8 must not reclassify market regime."
    },
    "group3_structure": {
      "role": "Dow and structural price-action context",
      "runtime_identity": "0.1.1/schema 3.0.0",
      "required_semantic_fields": [
        "structure state ID",
        "structure event ID",
        "event type including BOS, CHOCH, MSS and failed break when present",
        "direction",
        "source swing and protected-structure IDs",
        "symbol",
        "timeframe",
        "event_time",
        "confirmation_time",
        "availability_time",
        "config ID",
        "record hash"
      ],
      "exact_table_adapter": "PENDING_LOCAL_SCHEMA_INTROSPECTION",
      "prohibition": "Group 8 must not rediscover BOS, CHOCH, MSS, swings or protected structure."
    },
    "group4_zones": {
      "role": "breakout, retest, rejection, range and premium-discount anchors",
      "runtime_identity": "0.1.6/schema 4.5.0",
      "required_semantic_fields": [
        "zone ID",
        "zone type",
        "direction or role",
        "lower and upper bounds",
        "creation event time",
        "confirmation time",
        "availability time",
        "lifecycle state",
        "touch, penetration, invalidation and role-reversal transitions when present",
        "source IDs",
        "config ID",
        "record hash"
      ],
      "exact_table_adapter": "PENDING_LOCAL_SCHEMA_INTROSPECTION",
      "prohibition": "Group 8 must not recreate support, resistance, supply or demand zones."
    },
    "group5_liquidity": {
      "role": "liquidity narrative and sweep/reclaim context",
      "runtime_identity": "0.1.6/schema 5.1.0",
      "required_semantic_fields": [
        "liquidity pool ID",
        "liquidity event ID",
        "event type including sweep, reclaim, stop run, false break or inducement when present",
        "direction",
        "range or level",
        "source bar IDs",
        "event_time",
        "confirmation_time",
        "availability_time",
        "lifecycle state when present",
        "config ID",
        "record hash"
      ],
      "exact_table_adapter": "PENDING_LOCAL_SCHEMA_INTROSPECTION",
      "prohibition": "Group 8 must not recreate liquidity pools, sweeps or inducement."
    },
    "group6_imbalance_delivery": {
      "role": "displacement, imbalance, FVG, void, BPR, inversion and upstream evidence chains",
      "runtime_identity": "0.6.4/schema 6.35.0",
      "required_tables": [
        "config_registry",
        "dataset_registry",
        "dependency_registry",
        "displacement_legs",
        "displacement_validation_events",
        "fvg_events",
        "fvg_state_transitions",
        "fvg_visit_observations",
        "fvg_visit_reactions",
        "fvg_lifecycle_summary",
        "imbalance_variants",
        "liquidity_voids",
        "liquidity_void_members",
        "liquidity_void_state_transitions",
        "liquidity_void_lifecycle_summary",
        "bpr_relations",
        "bpr_state_transitions",
        "bpr_lifecycle_summary",
        "inversion_fvg_relations",
        "inversion_retest_observations",
        "mtf_imbalance_relations",
        "group6_evidence",
        "group6_audit_evidence"
      ],
      "minimum_displacement_fields": [
        "leg_id",
        "timeframe",
        "leg_kind",
        "direction",
        "start_bar_id",
        "end_bar_id",
        "start_time",
        "end_time",
        "confirmation_time",
        "availability_time",
        "bar_count",
        "origin_bar_id",
        "origin_window_start",
        "origin_window_end",
        "body_lower",
        "body_upper",
        "wick_lower",
        "wick_upper",
        "full_lower",
        "full_upper",
        "base_duration_bars",
        "first_impulse_bar_id",
        "last_opposing_bar_id",
        "origin_label",
        "initial_classification",
        "uncertain",
        "features_json",
        "feature_hash",
        "record_hash"
      ],
      "minimum_fvg_fields": [
        "fvg_id",
        "timeframe",
        "direction",
        "availability_time",
        "lower",
        "upper",
        "associated_leg_id",
        "associated_group3_event_id",
        "associated_group5_event_id",
        "record_hash"
      ],
      "minimum_evidence_fields": [
        "evidence_id",
        "subject_type",
        "subject_id",
        "source_group",
        "source_id",
        "relation_type",
        "source_timeframe",
        "availability_time",
        "details_json",
        "record_hash"
      ],
      "prohibition": "Group 8 must not reclassify FVG, displacement, void, BPR or inversion."
    },
    "group7_blocks": {
      "role": "Order Block and institutional-zone candidates, matches, evidence and lifecycle",
      "runtime_identity": "0.7.5/schema 7.5.0",
      "required_tables": [
        "config_registry",
        "dataset_registry",
        "dependency_registry",
        "definition_registry",
        "definition_candidates",
        "definition_matches",
        "block_evaluations",
        "institutional_zones",
        "zone_evidence",
        "zone_relations",
        "zone_state_transitions",
        "zone_visit_observations",
        "zone_lifecycle_summary",
        "group7_audit_evidence",
        "processing_checkpoints"
      ],
      "minimum_zone_fields": [
        "zone_id",
        "definition_id",
        "timeframe",
        "direction",
        "zone_label",
        "lower",
        "upper",
        "event_time",
        "confirmation_time",
        "availability_time",
        "source_leg_id",
        "candidate_id",
        "match_id",
        "origin_bar_id",
        "origin_window_start",
        "origin_window_end",
        "source_bar_id",
        "parent_zone_id",
        "creation_features_json",
        "feature_hash",
        "creation_hash"
      ],
      "minimum_zone_evidence_fields": [
        "evidence_id",
        "zone_id",
        "evidence_type",
        "source_group",
        "source_id",
        "relation_type",
        "availability_time",
        "details_json",
        "evidence_hash"
      ],
      "prohibition": "Group 8 must preserve candidate, match and lifecycle separation and must not choose a preferred block definition."
    }
  },
  "adapter_discovery_gate": {
    "required_before_engine_build": true,
    "steps": [
      "Restore the verified Groups 2-6 frozen runtime archive and validate archive SHA-256.",
      "Open each annual SQLite dependency read-only and list sqlite_master tables.",
      "Capture PRAGMA table_info, foreign_key_list and indexes for every consumed table.",
      "Map semantic fields to exact source columns without renaming upstream IDs.",
      "Store database filename, size, SHA-256, schema version, config ID and adapter-map hash.",
      "Reject legacy Group 6 artifacts that are not dukascopy_rebuild_v1."
    ]
  }
}
